{
  "name": "claude",
  "main": "worker.js",
  "compatibility_date": "2026-05-19",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "triggers": {
    "crons": ["*/2 * * * *", "*/3 * * * *", "*/15 * * * *", "0 7 * * *", "*/7 * * * *", "*/10 * * * *"]
  }
}
